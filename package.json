{
  "name": "global-rate-limiter",
  "version": "1.0.0",
  "description": "A distributed API rate limiter built with TypeScript, Express, Redis, and Lua.",
  "author": "Donsparkdev",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",

  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },

  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^6.1.0",
    "uuid": "^14.0.1"
  },

  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.3",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3"
  },

  "keywords": [
    "typescript",
    "express",
    "redis",
    "lua",
    "rate-limiter",
    "distributed",
    "api",
    "middleware"
  ]
}
"repository": {
  "type": "git",
  "url": "https://github.com/Donsparkdev/global-rate-limiter-.git"
},
"bugs": {
  "url": "https://github.com/Donsparkdev/global-rate-limiter-/issues"
